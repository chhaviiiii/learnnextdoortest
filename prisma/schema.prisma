model PlatformBankAccount {
  id                     String  @id @default(cuid())
  accountHolderName      String  @db.VarChar(120)
  bankName               String  @db.VarChar(120)
  accountNumberEncrypted String
  accountNumberLast4     String  @db.VarChar(4)
  ifscCode               String  @db.VarChar(11)
  upiId                  String? @db.VarChar(100)
  gstRegistrationNumber  String? @db.VarChar(20)

  // Optional workflow metadata for gated update flow before final save.
  changeStatus              String    @default("ACTIVE") // ACTIVE | PENDING_SUPER_ADMIN_CONFIRMATION
  pendingRequestedByAdminId String? // AdminUser.id
  pendingRequestedAt        DateTime?
  pendingApprovalToken      String?
  pendingApprovalExpiresAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CancellationRequest {
  id               String    @id @default(cuid())
  providerId       String
  provider         Provider  @relation(fields: [providerId], references: [id])
  classId          String
  class            Class     @relation(fields: [classId], references: [id])
  batchId          String?
  batch            Batch?    @relation(fields: [batchId], references: [id])
  scope            String // WORKSHOP | COURSE | BATCH
  reason           String
  totalRefund      Int       @default(0)
  affectedBookings Int       @default(0)
  status           String    @default("PROCESSING") // PROCESSING | COMPLETED | FAILED
  createdAt        DateTime  @default(now())
  completedAt      DateTime?

  refunds Refund[]
}

model Refund {
  id             String               @id @default(cuid())
  cancellationId String?
  cancellation   CancellationRequest? @relation(fields: [cancellationId], references: [id])
  bookingId      String               @unique
  booking        Booking              @relation(fields: [bookingId], references: [id])
  amount         Int
  method         String               @default("ORIGINAL") // ORIGINAL | UPI | MANUAL
  status         String               @default("QUEUED") // QUEUED | PROCESSING | COMPLETED | FAILED
  utr            String?
  createdAt      DateTime             @default(now())
  completedAt    DateTime?
}

model AuthSession {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  token      String   @unique
  device     String?
  location   String?
  current    Boolean  @default(false)
  lastActive DateTime @default(now())
  expiresAt  DateTime
  createdAt  DateTime @default(now())
}

model SupportTicket {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id])
  code           String    @unique
  subject        String
  category       String
  message        String
  imageUrl       String?
  reply          String?
  resolutionNote String?
  resolvedAt     DateTime?
  deleteAfter    DateTime? // set to resolvedAt + 7d on resolve
  mergedIntoId   String? // id of parent ticket this was merged into
  status         String    @default("OPEN") // OPEN | RESOLVED | CLOSED | MERGED
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model SupportCategory {
  id           String   @id @default(cuid())
  name         String   @unique @db.VarChar(80)
  active       Boolean  @default(true)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([active, displayOrder])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Settlement {
  id          String    @id @default(cuid())
  providerId  String
  provider    Provider  @relation(fields: [providerId], references: [id])
  code        String    @unique
  periodStart DateTime
  periodEnd   DateTime
  gross       Int
  commission  Int
  net         Int
  status      String    @default("PROCESSING") // PROCESSING | PENDING | PAID | FAILED | FUTURE
  utr         String?
  paidAt      DateTime?
  paidBy      String? // AdminUser.id
  notes       String?
  createdAt   DateTime  @default(now())
}

model OtpCode {
  id         String   @id @default(cuid())
  identifier String
  code       String
  channel    String
  role       String   @default("STUDENT")
  expiresAt  DateTime
  used       Boolean  @default(false)
  attempts   Int      @default(0)
  createdAt  DateTime @default(now())
}

// ============================================================================
// Admin portal models
// ============================================================================

model AdminUser {
  id           String    @id @default(cuid())
  username     String    @unique
  email        String?   @unique
  name         String
  passwordHash String
  role         String    @default("ADMIN") // SUPER_ADMIN | ADMIN
  status       String    @default("ACTIVE") // ACTIVE | SUSPENDED
  mustChangePw Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  createdBy    String? // AdminUser.id of the admin who created this account

  sessions AdminSession[]
}

model AdminSession {
  id         String    @id @default(cuid())
  adminId    String
  admin      AdminUser @relation(fields: [adminId], references: [id])
  token      String    @unique
  ip         String?
  userAgent  String?
  lastActive DateTime  @default(now())
  expiresAt  DateTime // absolute expiry
  createdAt  DateTime  @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String // AdminUser.id
  actorName  String // snapshot for durability (even after admin deletion)
  actorRole  String // SUPER_ADMIN | ADMIN
  module     String // KYC | LISTINGS | PAYMENTS | USERS | CONCERNS | SETTINGS | ...
  action     String // free-form verb, e.g., APPROVE_KYC, BLOCK_LISTING
  entityType String // Provider | Class | User | SupportTicket | Settlement | Refund | AdminUser
  entityId   String
  beforeJson String? // JSON-stringified snapshot
  afterJson  String?
  reason     String?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([module, createdAt])
  @@index([entityType, entityId])
  @@index([actorId, createdAt])
}

model EmailBlacklist {
  id        String   @id @default(cuid())
  email     String   @unique
  reason    String?
  addedBy   String? // AdminUser.id
  createdAt DateTime @default(now())
}

model PhoneBlacklist {
  id        String   @id @default(cuid())
  phone     String   @unique
  reason    String?
  addedBy   String? // AdminUser.id
  createdAt DateTime @default(now())
}
