// LearnNextDoor - Prisma schema (PostgreSQL, hosted on Supabase).
// State fields are stored as strings (kept portable from our original SQLite schema; validated at the app layer).
//
// Two connection strings are used:
//   DATABASE_URL → the PgBouncer pooler (port 6543) used by serverless runtime
//   DIRECT_URL   → the direct connection (port 5432) used by `prisma db push` / `prisma migrate`

generator client {
  provider      = "prisma-client-js"
  // rhel-openssl-3.0.x is what Vercel's Node runtime uses. "native" covers local dev on Mac/Linux.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String    @id @default(cuid())
  phone            String?   @unique
  email            String?   @unique
  name             String?
  role             String    @default("STUDENT") // STUDENT | PROVIDER | ADMIN
  avatar           String?
  suspended        Boolean   @default(false)
  suspendedAt      DateTime?
  suspensionReason String?
  createdAt        DateTime  @default(now())

  bookings      Booking[]
  reviews       Review[]
  sessions      AuthSession[]
  notifications Notification[]
  tickets       SupportTicket[]
  provider      Provider?
}

model Provider {
  id                 String    @id @default(cuid())
  userId             String    @unique
  user               User      @relation(fields: [userId], references: [id])
  providerCode       String    @unique // e.g., P001
  instituteName      String
  bio                String?
  area               String?
  address            String?
  upiId              String?
  upiVerified        Boolean   @default(false)
  kycStatus          String    @default("NOT_UPLOADED") // NOT_UPLOADED | PENDING | VERIFIED | REJECTED
  kycDocType         String?
  kycDocUrl          String?
  kycSubmittedAt     DateTime?
  kycVerifiedAt      DateTime?
  kycRejectionReason String?
  kycRevokedAt       DateTime?
  createdAt          DateTime  @default(now())

  classes       Class[]
  instructors   Instructor[]
  holidays      Holiday[]
  settlements   Settlement[]
  cancellations CancellationRequest[]
}

model Instructor {
  id                 String    @id @default(cuid())
  providerId         String
  provider           Provider  @relation(fields: [providerId], references: [id])
  name               String
  email              String?
  phone              String?
  specialty          String?
  kycStatus          String    @default("NOT_UPLOADED")
  kycDocType         String?
  kycDocUrl          String?
  kycSubmittedAt     DateTime?
  kycVerifiedAt      DateTime?
  kycRejectionReason String?
  createdAt          DateTime  @default(now())

  batches Batch[]
}

model Class {
  id                  String    @id @default(cuid())
  providerId          String
  provider            Provider  @relation(fields: [providerId], references: [id])
  title               String
  description         String?
  type                String // REGULAR | COURSE | WORKSHOP
  category            String
  subcategory         String?
  address             String?
  landmark            String?
  tagsCsv             String?
  imagesCsv           String?
  status              String    @default("ACTIVE") // ACTIVE | PAUSED | DRAFT | ARCHIVED
  // freeTrial       Boolean      @default(false)
  // trending        Boolean      @default(false)
  liveStatus          String    @default("PENDING_APPROVAL") // PENDING_APPROVAL | APPROVED | REJECTED | BLOCKED
  liveSubmittedAt     DateTime  @default(now())
  liveDecidedAt       DateTime?
  liveDecidedBy       String? // AdminUser.id
  liveReason          String? // rejection/block reason
  startDate           DateTime?
  registrationEndDate DateTime?
  endDate             DateTime?
  durationWeeks       Int?
  earlyBird           Boolean   @default(false)
  earlyBirdEndDate    DateTime?
  earlyBirdPrice      Int?
  earlyBirdSlots      Int?
  rating              Float?
  reviewsCount        Int       @default(0)
  createdAt           DateTime  @default(now())

  batches       Batch[]
  reviews       Review[]
  bookings      Booking[]
  holidays      Holiday[]
  // carouselSlides CarouselSlide[]
  cancellations CancellationRequest[]
}

model Batch {
  id                String      @id @default(cuid())
  classId           String
  class             Class       @relation(fields: [classId], references: [id], onDelete: Cascade)
  instructorId      String?
  instructor        Instructor? @relation(fields: [instructorId], references: [id])
  name              String
  classDaysCsv      String? // "Mon,Wed,Fri"
  startDate         DateTime?
  fromTime          String // "07:00"
  toTime            String // "08:00"
  pricePer4Weeks    Int
  maxStudents       Int
  enrolled          Int         @default(0)
  freeTrialEnabled  Boolean     @default(false)
  freeTrialSessions Int         @default(0)
  imageUrl          String?
  createdAt         DateTime    @default(now())

  bookings      Booking[]
  holidays      Holiday[]
  cancellations CancellationRequest[]
}

model Booking {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  classId       String
  class         Class     @relation(fields: [classId], references: [id])
  batchId       String
  batch         Batch     @relation(fields: [batchId], references: [id])
  mode          String    @default("ENROLL") // ENROLL | TRIAL
  amount        Int       @default(0)
  status        String    @default("CONFIRMED") // CONFIRMED | PENDING | CANCELLED | COMPLETED | REFUNDED
  cancelledAt   DateTime?
  extendedUntil DateTime? // new effective end date after holiday extension
  refundAmount  Int       @default(0)
  createdAt     DateTime  @default(now())

  refund Refund?
}

model Review {
  id        String   @id @default(cuid())
  classId   String
  class     Class    @relation(fields: [classId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  rating    Int
  comment   String
  createdAt DateTime @default(now())
}

model Holiday {
  id               String   @id @default(cuid())
  providerId       String
  provider         Provider @relation(fields: [providerId], references: [id])
  classId          String?
  class            Class?   @relation(fields: [classId], references: [id])
  batchId          String?
  batch            Batch?   @relation(fields: [batchId], references: [id])
  date             DateTime
  reason           String?
  affectsAll       Boolean  @default(true) // true = all provider batches; false = scoped via classId/batchId
  compensation     String   @default("EXTEND") // EXTEND | REFUND | NONE
  sessionsAffected Int      @default(0)
  createdAt        DateTime @default(now())
}

model Category {
  id           String   @id @default(cuid())
  categoryCode String   @unique
  name         String   @unique @db.VarChar(80)
  icon         String?  @db.VarChar(20)
  hue          String?  @db.VarChar(80)
  active       Boolean  @default(true)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  subcategories Subcategory[]

  @@index([active, displayOrder])
}

model Subcategory {
  id              String   @id @default(cuid())
  subcategoryCode String   @unique
  categoryId      String
  category        Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name            String   @db.VarChar(80)
  active          Boolean  @default(true)
  displayOrder    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([categoryId, name])
  @@index([categoryId, active, displayOrder])
}

