# ─── Database (Supabase Postgres) ────────────────────────────────────────────
# Supabase exposes TWO connection strings — grab both from the project's
# Settings → Database → Connection string section.
#
# DATABASE_URL  = the "Transaction" pooler (port 6543). Used by the app at runtime.
#                 Must include ?pgbouncer=true&connection_limit=1 for serverless on Vercel.
# DIRECT_URL    = the "Session" direct connection (port 5432). Used by `prisma db push` / migrate.
#
# Example shapes (replace [PROJECT-REF] and [PASSWORD]):
#   postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
#   postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:5432/postgres
DATABASE_URL=
DIRECT_URL=

# Session secret for cookie signing. Generate locally with: openssl rand -hex 32
SESSION_SECRET="replace-me-with-a-long-random-string"

# ─── OTP delivery ────────────────────────────────────────────────────────────
# OTP_DEV_MODE=true is local-only: the server prints OTPs to the console and
# returns them in the /api/auth/send-otp response.
#
# For production/proper login: keep OTP_DEV_MODE=false and fill provider vars
# for every channel enabled in the UI. Missing keys will fail loudly instead of
# silently falling back to dev codes.
OTP_DEV_MODE=false

# ─── Resend (Email OTP) ──────────────────────────────────────────────────────
# Sign up at https://resend.com → API Keys → create a new key.
# Free tier: 3,000 emails/month, 100/day. Plenty for MVP.
#
# EMAIL_FROM MUST be a verified sender in Resend — OR leave it as the default
# "LearnNextDoor <onboarding@resend.dev>" for testing before you verify a domain.
# Once you verify your domain in Resend, change this to e.g.
#   "LearnNextDoor <noreply@yourdomain.com>"
RESEND_API_KEY=
EMAIL_FROM="LearnNextDoor <onboarding@resend.dev>"

# ─── Twilio (SMS OTP) ───────────────────────────────────────────────────────
# Create a Twilio Messaging-capable phone number and use it as TWILIO_SMS_FROM
# in E.164 format, e.g. "+15551234567".
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
# Fallback if you do not use Twilio API keys. Prefer API keys for production.
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=

# Optional WhatsApp sender. The UI keeps WhatsApp disabled until you explicitly
# add a sender and turn the UI on.
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Razorpay - optional, for real payments
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Provider support contact shown inside the provider portal
PROVIDER_SUPPORT_WHATSAPP="+91 90000 00000"
PROVIDER_SUPPORT_EMAIL=support@learnnextdoor.in
PROVIDER_SUPPORT_HELP_LABEL="Open KB →"

# Anthropic - powers the student-side AI discovery assistant ("Ask Zoe" floating button).
# If blank, the chat UI still renders but will return an error when a message is sent.
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# ─── Admin portal (Super Admin seed) ─────────────────────────────────────────
# The very first Super Admin account is seeded on demand when someone hits
# /admin/login AND no admin rows exist yet. After that, new admins are invited
# from Settings → Admin Credentials (by the Super Admin).
#
# Requirements for ADMIN_SEED_PASSWORD:
#   - at least 12 characters
#   - mix of upper + lower + digit + symbol
# Change this immediately after first login (the UI forces a password reset).
ADMIN_SEED_USERNAME=superadmin
ADMIN_SEED_PASSWORD="Ch@ngeMeNow!2026"
ADMIN_SEED_EMAIL=admin@learnnextdoor.in
ADMIN_SEED_NAME="Super Admin"
